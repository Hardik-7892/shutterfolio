# Optional: SESSION_SECRET (auto-derived from ADMIN_PASSWORD if omitted)

GITHUB_PAT=github_pat_...
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose-a-strong-password
SESSION_SECRET=generate-a-long-random-string
